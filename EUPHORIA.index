<!-- ===================== MODAL ===================== -->
<div class="modal-bg" id="modalBg">
  <div class="modal" id="modalContent"></div>
</div>
<div class="toast" id="toast"></div>

<script>
/* ============================================================
   구글 시트 연동 설정
   1) 새 구글 스프레드시트를 만들고 확장 프로그램 > Apps Script에서
      함께 제공한 Code.gs 내용을 붙여넣으세요.
   2) 배포 > 새 배포 > 유형: 웹 앱
      - 실행 계정: 나
      - 액세스 권한: 전체 허용 (Anyone)
   3) 배포 후 나오는 웹 앱 URL을 아래 API_URL에 붙여넣으세요.
   ============================================================ */
const API_URL = "https://script.google.com/macros/s/AKfycbzL-aULJLrhYjRwj9_dHrz6Lr5xTkO0YKOJ9vOKaqa-qr6Mjfw07s2ONnUuWVuzc2Z0gQ/exec";

async function apiCall(action, payload={}){
  if(!API_URL || API_URL.includes('여기에')){
    toast('먼저 Apps Script 배포 URL을 코드 상단(API_URL)에 등록해주세요.');
    return { ok:false, message:'API_URL not configured' };
  }
  try{
    const res = await fetch(API_URL, {
      method:'POST',
      headers:{ 'Content-Type':'text/plain;charset=utf-8' }, // preflight(OPTIONS) 방지용
      body: JSON.stringify(Object.assign({action}, payload))
    });
    return await res.json();
  }catch(err){
    toast('서버(구글 시트)에 연결하지 못했어요.');
    return { ok:false, message: err.message };
  }
}

/* ============ 시드 데이터 ============ */
const EMOJI = {"유기견":"🐕","유기묘":"🐈","은퇴 경주마":"🐎","야생동물":"🦉","기타":"🐾"};
const BG = {"유기견":"#eef3ea","유기묘":"#f3ecdf","은퇴 경주마":"#eef0e6","야생동물":"#e7eee8","기타":"#f1ede1"};

let animals = [
  {id:1, name:"보리", type:"유기견", org:"서울 유기동물 보호센터", story:"교통사고를 당한 채 방치되어 있던 보리는 뒷다리 재활 치료를 받고 있어요. 새 가족을 만날 그날까지, 치료비가 필요합니다.", target:1500000, raised:842000},
  {id:2, name:"질주", type:"은퇴 경주마", org:"제주 은퇴마 보호협회", story:"7년간 트랙을 달리며 상금을 벌어다준 질주는 부상 이후 은퇴했어요. 도살장 대신 평화로운 여생을 보낼 목장 비용이 필요합니다.", target:5000000, raised:3120000},
  {id:3, name:"두부", type:"유기묘", org:"인천 캣맘 연합", story:"길에서 태어나 눈병을 앓던 두부는 구조 후 한쪽 시력을 잃었어요. 남은 치료와 중성화 수술이 필요한 상태예요.", target:800000, raised:611000},
  {id:4, name:"뭉치", type:"유기견", org:"대전 동물사랑센터", story:"11살 노령견 뭉치는 심장 질환으로 매달 약을 먹어야 해요. 마지막까지 편안하게 지낼 수 있도록 도와주세요.", target:1200000, raised:305000},
  {id:5, name:"부엉", type:"야생동물", org:"국립 야생동물 재활센터", story:"풍력발전기 날개에 부딪혀 날개를 다친 수리부엉이 부엉이는 야생 복귀를 위한 재활 훈련을 받고 있어요.", target:900000, raised:150000},
  {id:6, name:"까망이", type:"유기묘", org:"인천 캣맘 연합", story:"태어난 지 3주 만에 어미를 잃은 까망이는 사람 손으로 젖병 수유를 받으며 자라고 있어요.", target:400000, raised:388000},
];

let orgs = [
  {name:"서울 유기동물 보호센터", loc:"서울", desc:"매년 300마리 이상의 유기견을 구조하고 재활을 돕는 비영리 단체입니다.", count: "현재 42마리 보호중"},
  {name:"제주 은퇴마 보호협회", loc:"제주", desc:"경주마·승마용으로 쓰이다 은퇴한 말들에게 목초지를 제공합니다.", count:"현재 11마리 보호중"},
  {name:"인천 캣맘 연합", loc:"인천", desc:"지역 길고양이 중성화(TNR)와 구조·치료 활동을 이어가는 자원봉사 단체입니다.", count:"현재 27마리 보호중"},
  {name:"국립 야생동물 재활센터", loc:"경기", desc:"다친 야생동물을 치료해 자연으로 돌려보내는 공공 재활 기관입니다.", count:"현재 19마리 보호중"},
];

let currentUser = null;   // {id, email, name, createdAt}
let userAccount = null;   // {accountNumber, balance, linkedAt}
let userDonations = [];   // 로그인한 사용자의 기부 내역 (구글 시트에서 로드)
let selectedAnimalId = animals[0].id;
let activeFilter = "전체";
let linked = false;
let balance = 0;
let selectedPeriodHero = "매주";
let selectedPeriod = "매주";

function won(n){ return "₩" + Math.round(n).toLocaleString("ko-KR"); }
function toast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(window.__toastT);
  window.__toastT = setTimeout(()=>t.classList.remove('show'), 2600);
}

/* ============ 네비게이션 ============ */
document.querySelectorAll('[data-nav]').forEach(el=>{
  el.addEventListener('click', ()=>{
    document.getElementById(el.dataset.nav).scrollIntoView({behavior:'smooth', block:'start'});
    document.querySelectorAll('.nav-links button[data-nav]').forEach(b=>b.classList.remove('active'));
    const match = document.querySelector('.nav-links button[data-nav="'+el.dataset.nav+'"]');
    if(match) match.classList.add('active');
  });
});

/* ============ 동물 소개 렌더링 ============ */
function renderFilters(){
  const types = ["전체", ...new Set(animals.map(a=>a.type))];
  const box = document.getElementById('filters');
  box.innerHTML = types.map(t=>`<button data-t="${t}" class="${t===activeFilter?'active':''}">${t}</button>`).join('');
  box.querySelectorAll('button').forEach(b=>b.addEventListener('click', ()=>{
    activeFilter = b.dataset.t; renderFilters(); renderAnimalGrid();
  }));
}

function renderAnimalGrid(){
  const grid = document.getElementById('animalGrid');
  const list = animals.filter(a => activeFilter==="전체" || a.type===activeFilter);
  grid.innerHTML = list.map(a=>{
    const pct = Math.min(100, Math.round(a.raised/a.target*100));
    return `
    <div class="a-card">
      <div class="a-media" style="background:${BG[a.type]}">
        <span class="a-tag">${a.type}</span>
        ${EMOJI[a.type]}
      </div>
      <div class="a-body">
        <div class="a-name">${a.name}</div>
        <div class="a-org">${a.org}</div>
        <div class="a-story">${a.story.slice(0,54)}${a.story.length>54?'…':''}</div>
        <div class="progress"><div style="width:${pct}%"></div></div>
        <div class="a-stats"><span>${won(a.raised)} 모금</span><span>${pct}%</span></div>
        <div class="a-actions">
          <button class="btn btn-ghost" data-view="${a.id}">이야기 보기</button>
          <button class="btn btn-primary" data-donate="${a.id}">기부하기</button>
        </div>
      </div>
    </div>`;
  }).join('') + `
    <button class="add-card" id="openAddAnimal">
      <span class="plus">＋</span>
      기관·운영자 전용<br>보호 동물 등록하기
    </button>`;

  grid.querySelectorAll('[data-view]').forEach(b=>b.addEventListener('click', ()=>openAnimalModal(+b.dataset.view)));
  grid.querySelectorAll('[data-donate]').forEach(b=>b.addEventListener('click', ()=>{
    selectedAnimalId = +b.dataset.donate;
    document.getElementById('donate').scrollIntoView({behavior:'smooth'});
    renderDonateAnimal();
  }));
  document.getElementById('openAddAnimal').addEventListener('click', ()=>{
    document.getElementById('orgs').scrollIntoView({behavior:'smooth'});
    document.getElementById('af_name').focus();
  });
}

function openAnimalModal(id){
  const a = animals.find(x=>x.id===id);
  const pct = Math.min(100, Math.round(a.raised/a.target*100));
  document.getElementById('modalContent').className = 'modal';
  document.getElementById('modalContent').innerHTML = `
    <button class="modal-close" id="mClose">✕</button>
    <div class="m-emoji">${EMOJI[a.type]}</div>
    <h3>${a.name}</h3>
    <div class="m-org">${a.org} · ${a.type}</div>
    <div class="m-story">${a.story}</div>
    <div class="progress"><div style="width:${pct}%"></div></div>
    <div class="a-stats" style="margin-top:8px;"><span>${won(a.raised)} / ${won(a.target)}</span><span>${pct}%</span></div>
    <button class="btn btn-primary btn-block" style="margin-top:18px;" id="mDonateBtn">이 동물에게 기부하기</button>
  `;
  document.getElementById('modalBg').classList.add('open');
  document.getElementById('mClose').addEventListener('click', closeModal);
  document.getElementById('mDonateBtn').addEventListener('click', ()=>{
    selectedAnimalId = id; closeModal();
    document.getElementById('donate').scrollIntoView({behavior:'smooth'});
    renderDonateAnimal();
  });
}
function closeModal(){ document.getElementById('modalBg').classList.remove('open'); }
document.getElementById('modalBg').addEventListener('click', e=>{ if(e.target.id==='modalBg') closeModal(); });

/* ============ 히어로 패스북 데모 ============ */
let heroBalance = 128305;
let heroDigit = 3;
function renderHeroDigits(){
  const str = String(heroBalance);
  const box = document.getElementById('heroDigits');
  let html = '';
  for(let i=0;i<str.length;i++){
    const fromRight = str.length - i;
    const isDonate = fromRight <= heroDigit;
    html += `<div class="digit ${isDonate?'donate':'kept'}" data-pos="${fromRight}">${str[i]}</div>`;
    const remainder = fromRight - 1;
    if(remainder>0 && remainder % 3 === 0) html += `<div class="comma">,</div>`;
  }
  box.innerHTML = html;
  box.querySelectorAll('.digit').forEach(d=>d.addEventListener('click', ()=>{
    heroDigit = +d.dataset.pos; updateHero();
  }));
}
function updateHero(){
  renderHeroDigits();
  const mod = Math.pow(10, heroDigit);
  const donateAmt = heroDigit >= String(heroBalance).length ? heroBalance : heroBalance % mod;
  const kept = heroBalance - donateAmt;
  document.getElementById('heroHint').textContent = `오른쪽 ${heroDigit}자리까지 기부됩니다`;
  document.getElementById('heroAmount').textContent = won(donateAmt);
  document.getElementById('heroKept').textContent = won(kept);
}
function renderHeroPeriod(){
  const periods = ["매일","매주","매달","분기"];
  document.getElementById('heroPeriod').innerHTML = periods.map(p=>`<button class="${p===selectedPeriodHero?'active':''}" data-p="${p}">${p}</button>`).join('');
  document.querySelectorAll('#heroPeriod button').forEach(b=>b.addEventListener('click', ()=>{
    selectedPeriodHero = b.dataset.p; renderHeroPeriod();
  }));
}
renderHeroPeriod();
updateHero();

/* ============ 모금 섹션 ============ */
function renderPickList(){
  document.getElementById('pickList').innerHTML = animals.map(a=>
    `<button class="pick-chip ${a.id===selectedAnimalId?'active':''}" data-id="${a.id}">${EMOJI[a.type]} ${a.name}</button>`
  ).join('');
  document.querySelectorAll('.pick-chip').forEach(b=>b.addEventListener('click', ()=>{
    selectedAnimalId = +b.dataset.id; renderPickList(); renderDonateAnimal();
  }));
}
function renderDonateAnimal(){
  const a = animals.find(x=>x.id===selectedAnimalId);
  document.getElementById('selectedAnimalBox').innerHTML = `
    <div class="emoji">${EMOJI[a.type]}</div>
    <div class="info"><div class="n">${a.name}</div><div class="s">${a.org} · ${a.type}</div></div>
  `;
  document.querySelectorAll('.pick-chip').forEach(b=>b.classList.toggle('active', +b.dataset.id===selectedAnimalId));
  document.getElementById('sumAnimal').textContent = a.name;
  updateSummary();
}

function renderLinkBox(){
  const box = document.getElementById('linkBox');
  if(linked && userAccount){
    box.classList.add('linked');
    box.innerHTML = `
      <div style="font-size:12px;color:var(--forest-mid);font-weight:600;">✓ 계좌 연결 완료 (${userAccount.accountNumber})</div>
      <div class="mono" style="font-size:22px;font-weight:700;color:var(--forest-deep);margin-top:6px;">${won(balance)}</div>
      <div style="font-size:11.5px;color:#8a9488;margin-top:2px;">마이페이지에 등록된 계좌 · 실시간 데모 잔액</div>
      <button class="btn btn-ghost btn-sm" style="margin-top:10px;" id="linkBtn">다른 계좌로 변경</button>
    `;
  } else if(!currentUser){
    box.classList.remove('linked');
    box.innerHTML = `
      <div style="font-size:13px;color:#586359;margin-bottom:10px;">로그인 후 계좌를 연결하면 자동 기부를 시작할 수 있어요</div>
      <button class="btn btn-primary btn-sm" id="linkBtn">로그인하고 계좌 연결하기</button>
    `;
  } else {
    box.classList.remove('linked');
    box.innerHTML = `
      <div style="font-size:13px;color:#586359;margin-bottom:10px;">계좌를 연결하면 실시간 잔액을 불러와요 (데모 가상 연동)</div>
      <button class="btn btn-primary btn-sm" id="linkBtn">가상 계좌 연결하기</button>
    `;
  }
  document.getElementById('linkBtn').addEventListener('click', handleLinkClick);
}

async function handleLinkClick(){
  if(!currentUser){ openAuthModal('login'); return; }
  await linkAccountFlow();
}

async function linkAccountFlow(){
  const num = prompt('연결할 가상 계좌번호를 입력해주세요 (예: 302-1234-5678)');
  if(!num) return;
  const bal = Math.floor(Math.random()*900000)+50000;
  const res = await apiCall('saveAccount', { userId: currentUser.id, accountNumber:num, balance:bal });
  if(res.ok){
    userAccount = { accountNumber:num, balance:bal, linkedAt: new Date().toISOString() };
    linked = true; balance = bal;
    renderMpAccount();
    renderLinkBox(); renderDonateDigits(); updateSummary();
    toast('계좌가 등록되었어요.');
  } else {
    toast(res.message || '계좌 등록에 실패했어요.');
  }
}

const digitSlider = document.getElementById('digitSlider');
digitSlider.addEventListener('input', ()=>{
  document.getElementById('digitVal').textContent = digitSlider.value;
  renderDonateDigits();
  updateSummary();
});

function renderDonateDigits(){
  const wrap = document.getElementById('donateDigits');
  if(!linked){ wrap.innerHTML = `<div style="font-size:12.5px;color:#8a9488;">계좌를 연결하면 잔액이 표시됩니다</div>`; return; }
  const digit = +digitSlider.value;
  const str = String(balance);
  let html = '';
  for(let i=0;i<str.length;i++){
    const fromRight = str.length - i;
    const isDonate = fromRight <= digit;
    html += `<div class="digit ${isDonate?'donate':'kept'}" style="cursor:default;width:28px;height:38px;font-size:22px;">${str[i]}</div>`;
  }
  wrap.innerHTML = html;
}

function renderPeriodGrid(){
  const periods = ["매일","매주","매달","분기"];
  document.getElementById('periodGrid').innerHTML = periods.map(p=>`<button class="${p===selectedPeriod?'active':''}" data-p="${p}">${p}</button>`).join('');
  document.querySelectorAll('#periodGrid button').forEach(b=>b.addEventListener('click', ()=>{
    selectedPeriod = b.dataset.p; renderPeriodGrid(); updateSummary();
  }));
}

function calcDonation(){
  if(!linked) return 0;
  const digit = +digitSlider.value;
  const mod = Math.pow(10, digit);
  return digit >= String(balance).length ? balance : balance % mod;
}

function updateSummary(){
  const digit = +digitSlider.value;
  document.getElementById('sumBalance').textContent = linked ? won(balance) : "계좌 미연결";
  document.getElementById('sumDigit').textContent = digit + "자리";
  document.getElementById('sumPeriod').textContent = selectedPeriod;
  document.getElementById('sumAmount').textContent = won(calcDonation());
}

document.getElementById('confirmDonate').addEventListener('click', async ()=>{
  if(!currentUser){ toast("로그인 후 기부할 수 있어요"); openAuthModal('login'); return; }
  if(!linked){ toast("먼저 계좌를 연결해주세요"); return; }
  const amt = calcDonation();
  if(amt<=0){ toast("기부 금액이 0원이에요. 자릿수를 조정해보세요"); return; }
  const a = animals.find(x=>x.id===selectedAnimalId);
  const btn = document.getElementById('confirmDonate');
  btn.disabled = true; btn.textContent = '처리중...';
  const res = await apiCall('addDonation', { userId: currentUser.id, animalId:a.id, animalName:a.name, amount:amt, digit:+digitSlider.value, period:selectedPeriod });
  btn.disabled = false; btn.textContent = '이 조건으로 정기 기부 시작';
  if(res.ok){
    a.raised += amt;
    userDonations.unshift({ animalName:a.name, amount:amt, period:selectedPeriod, digit:+digitSlider.value, createdAt: (res.donation && res.donation.createdAt) || new Date().toISOString() });
    renderHist();
    renderMpDonations();
    renderAnimalGrid();
    toast(`${a.name}에게 ${selectedPeriod}마다 ${won(amt)}씩 자동 기부를 시작했어요 🎉`);
  } else {
    toast(res.message || '기부 처리에 실패했어요.');
  }
});

function renderHist(){
  const box = document.getElementById('histList');
  if(!currentUser){ box.innerHTML = `<div class="empty-note">로그인하면 기부 내역이 여기에 표시돼요.</div>`; return; }
  if(!userDonations || userDonations.length===0){ box.innerHTML = `<div class="empty-note">아직 기부 내역이 없어요.</div>`; return; }
  box.innerHTML = userDonations.slice(0,5).map(h=>`
    <div class="hist-item"><span>${h.animalName} · ${h.period} (${h.digit}자리)</span><span class="h-amt">${won(h.amount)}</span></div>
  `).join('');
}

/* ============ 인증 (회원가입 / 로그인) ============ */
function renderAuthArea(){
  const box = document.getElementById('authArea');
  if(currentUser){
    box.innerHTML = `<div class="user-chip"><span class="u-name">${currentUser.name}님</span><button id="logoutBtn">로그아웃</button></div>`;
    document.getElementById('logoutBtn').addEventListener('click', logout);
  } else {
    box.innerHTML = `<button class="btn btn-ghost btn-sm" id="loginBtn">로그인</button><button class="btn btn-primary btn-sm" id="signupBtn">회원가입</button>`;
    document.getElementById('loginBtn').addEventListener('click', ()=>openAuthModal('login'));
    document.getElementById('signupBtn').addEventListener('click', ()=>openAuthModal('signup'));
  }
}

function openAuthModal(mode){
  renderAuthModalContent(mode);
  document.getElementById('modalBg').classList.add('open');
}

function renderAuthModalContent(mode){
  document.getElementById('modalContent').className = 'modal';
  document.getElementById('modalContent').innerHTML = `
    <button class="modal-close" id="mClose">✕</button>
    <h3>EUPHORIA 회원</h3>
    <div class="auth-tabs">
      <button data-m="login" class="${mode==='login'?'active':''}">로그인</button>
      <button data-m="signup" class="${mode==='signup'?'active':''}">회원가입</button>
    </div>
    <form class="auth-form" id="authForm">
      ${mode==='signup' ? `<div class="field"><label>이름</label><input required id="auth_name" placeholder="홍길동"></div>` : ''}
      <div class="field"><label>이메일</label><input required type="email" id="auth_email" placeholder="you@example.com"></div>
      <div class="field"><label>비밀번호</label><input required type="password" id="auth_pw" placeholder="••••••••"></div>
      <button type="submit" class="btn btn-primary btn-block">${mode==='login'?'로그인':'회원가입하고 시작하기'}</button>
    </form>
    <div class="auth-note">회원 정보는 연동된 구글 시트에 저장돼요. 데모 서비스이니 실제로 사용하는 비밀번호는 입력하지 마세요.</div>
  `;
  document.getElementById('mClose').addEventListener('click', closeModal);
  document.querySelectorAll('.auth-tabs button').forEach(b=>b.addEventListener('click', ()=>renderAuthModalContent(b.dataset.m)));
  document.getElementById('authForm').addEventListener('submit', async (e)=>{
    e.preventDefault();
    const email = document.getElementById('auth_email').value;
    const pw = document.getElementById('auth_pw').value;
    const submitBtn = e.target.querySelector('button[type=submit]');
    submitBtn.disabled = true; submitBtn.textContent = '처리중...';
    let res;
    if(mode === 'signup'){
      const name = document.getElementById('auth_name').value;
      res = await apiCall('signup', { email, password: pw, name });
    } else {
      res = await apiCall('login', { email, password: pw });
    }
    submitBtn.disabled = false; submitBtn.textContent = mode==='login' ? '로그인' : '회원가입하고 시작하기';
    if(res.ok){
      currentUser = res.user;
      closeModal();
      renderAuthArea();
      toast(`${currentUser.name}님, 환영해요!`);
      await loadUserData();
      renderMypage();
      renderLinkBox();
      renderDonateDigits();
      updateSummary();
      renderHist();
    } else {
      toast(res.message || '오류가 발생했어요.');
    }
  });
}

async function loadUserData(){
  if(!currentUser) return;
  const accRes = await apiCall('getAccount', { userId: currentUser.id });
  if(accRes.ok && accRes.account){ userAccount = accRes.account; linked = true; balance = userAccount.balance; }
  const donRes = await apiCall('getDonations', { userId: currentUser.id });
  if(donRes.ok) userDonations = donRes.donations || [];
}

function logout(){
  currentUser = null; userAccount = null; userDonations = []; linked = false; balance = 0;
  renderAuthArea(); renderMypage(); renderLinkBox(); renderDonateDigits(); updateSummary(); renderHist();
  toast('로그아웃 되었어요.');
}

/* ============ 마이페이지 ============ */
function renderMypage(){
  const box = document.getElementById('mypageBody');
  if(!currentUser){
    box.innerHTML = `
      <div class="mp-locked">
        <div class="lock-emoji">🔒</div>
        <h3>로그인이 필요해요</h3>
        <p>로그인하면 계좌를 등록하고 기부 내역을 확인할 수 있어요.</p>
        <button class="btn btn-primary" id="mpLoginBtn">로그인 / 회원가입</button>
      </div>`;
    document.getElementById('mpLoginBtn').addEventListener('click', ()=>openAuthModal('login'));
    return;
  }
  box.innerHTML = `
    <div class="mypage-grid">
      <div>
        <div class="mp-card">
          <h4>👤 내 정보</h4>
          <div class="mp-account-row"><span>이름</span><span>${currentUser.name}</span></div>
          <div class="mp-account-row" style="border-bottom:none;"><span>이메일</span><span>${currentUser.email}</span></div>
        </div>
        <div class="mp-card">
          <h4>💳 등록된 계좌</h4>
          <div id="mpAccountBox"></div>
        </div>
      </div>
      <div class="mp-card">
        <h4>🐾 내 기부 내역</h4>
        <div id="mpDonationBox"></div>
      </div>
    </div>`;
  renderMpAccount();
  renderMpDonations();
}

function renderMpAccount(){
  const box = document.getElementById('mpAccountBox');
  if(!box) return;
  if(userAccount){
    box.innerHTML = `
      <div class="mp-account-row"><span>계좌</span><span class="mono">${userAccount.accountNumber}</span></div>
      <div class="mp-account-row"><span>잔액</span><span class="mono">${won(userAccount.balance)}</span></div>
      <div class="mp-account-row" style="border-bottom:none;"><span>연결일</span><span>${new Date(userAccount.linkedAt).toLocaleDateString('ko-KR')}</span></div>
      <button class="btn btn-ghost btn-sm btn-block" style="margin-top:12px;" id="mpRelink">다른 계좌로 변경</button>`;
    document.getElementById('mpRelink').addEventListener('click', linkAccountFlow);
  } else {
    box.innerHTML = `<p style="font-size:12.8px;color:#5b655c;margin-bottom:12px;">등록된 계좌가 없어요.</p>
      <button class="btn btn-primary btn-sm btn-block" id="mpLink">계좌 등록하기</button>`;
    document.getElementById('mpLink').addEventListener('click', linkAccountFlow);
  }
}

function renderMpDonations(){
  const box = document.getElementById('mpDonationBox');
  if(!box) return;
  if(!userDonations || userDonations.length===0){
    box.innerHTML = `<div class="empty-note">아직 기부 내역이 없어요.</div>`;
    return;
  }
  box.innerHTML = `
    <table class="mp-table">
      <thead><tr><th>동물</th><th>금액</th><th>주기</th><th>날짜</th></tr></thead>
      <tbody>
        ${userDonations.map(d=>`<tr><td>${d.animalName}</td><td class="amt">${won(d.amount)}</td><td>${d.period}</td><td>${new Date(d.createdAt).toLocaleDateString('ko-KR')}</td></tr>`).join('')}
      </tbody>
    </table>`;
}

/* ============ 이용안내 ============ */
document.getElementById('guideBtn').addEventListener('click', ()=>{
  document.getElementById('modalContent').className = 'modal wide';
  document.getElementById('modalContent').innerHTML = `
    <button class="modal-close" id="mClose">✕</button>
    <h3>EUPHORIA 이용 안내</h3>
    <p style="text-align:center;font-size:12.5px;color:#8a9488;margin-top:6px;">이렇게 이용해보세요</p>
    <div style="margin-top:18px;">
      <div class="guide-item"><div class="guide-num">1</div><div><h5>회원가입 &amp; 로그인</h5><p>이메일·이름으로 간단히 가입하면 내 계좌와 기부 내역이 구글 시트에 안전하게 저장돼요.</p></div></div>
      <div class="guide-item"><div class="guide-num">2</div><div><h5>계좌 등록</h5><p>마이페이지 또는 모금 화면의 '통장 연결' 단계에서 계좌를 등록하면, 잔액을 불러와 자릿수 기부에 사용할 수 있어요.</p></div></div>
      <div class="guide-item"><div class="guide-num">3</div><div><h5>동물 이야기 둘러보기</h5><p>유기견·유기묘·은퇴 경주마 등 사연을 가진 동물들의 이야기를 읽고 마음이 가는 동물을 찾아보세요.</p></div></div>
      <div class="guide-item"><div class="guide-num">4</div><div><h5>자릿수 모금 설정</h5><p>기부할 동물, 자릿수(1~100), 주기(매일/매주/매달/분기)를 정하면 통장 잔액의 끝자리만큼 부담 없이 자동 기부돼요.</p></div></div>
      <div class="guide-item"><div class="guide-num">5</div><div><h5>기부 내역 확인</h5><p>마이페이지에서 내가 기부한 동물, 금액, 날짜를 언제든 확인할 수 있어요.</p></div></div>
      <div class="guide-item"><div class="guide-num">6</div><div><h5>기관 연계</h5><p>동물 보호 기관은 보호 중인 동물을 직접 등록하고, 새로운 기관은 파트너 참여를 신청할 수 있어요.</p></div></div>
    </div>
  `;
  document.getElementById('modalBg').classList.add('open');
  document.getElementById('mClose').addEventListener('click', closeModal);
});

/* ============ 기관 연계 ============ */
function renderOrgs(){
  document.getElementById('orgGrid').innerHTML = orgs.map(o=>`
    <div class="org-card">
      <div class="o-icon">🏛️</div>
      <div class="o-name">${o.name}</div>
      <div class="o-loc">${o.loc}</div>
      <div class="o-desc">${o.desc}</div>
      <div class="o-meta">${o.count}</div>
    </div>
  `).join('');
}

document.getElementById('animalForm').addEventListener('submit', e=>{
  e.preventDefault();
  const type = document.getElementById('af_type').value;
  const newAnimal = {
    id: Date.now(),
    name: document.getElementById('af_name').value,
    type,
    org: document.getElementById('af_org').value,
    story: document.getElementById('af_story').value,
    target: +document.getElementById('af_target').value || 500000,
    raised: 0
  };
  animals.unshift(newAnimal);
  e.target.reset();
  renderFilters(); renderAnimalGrid(); renderPickList();
  toast(`${newAnimal.name}의 이야기가 등록되었어요 🐾`);
  document.getElementById('animals').scrollIntoView({behavior:'smooth'});
});

document.getElementById('orgForm').addEventListener('submit', e=>{
  e.preventDefault();
  const newOrg = {
    name: document.getElementById('of_name').value,
    loc: document.getElementById('of_loc').value,
    desc: document.getElementById('of_desc').value,
    count: "심사 진행중"
  };
  orgs.unshift(newOrg);
  e.target.reset();
  renderOrgs();
  toast(`${newOrg.name} 파트너 신청이 접수되었어요`);
});

/* ============ 초기 렌더 ============ */
renderFilters();
renderAnimalGrid();
renderPickList();
renderDonateAnimal();
renderPeriodGrid();
renderOrgs();
renderAuthArea();
renderMypage();
renderLinkBox();
renderHist();
setInterval(()=>{ /* keep passbook demo idle-safe */ }, 0);
</script>
</body>
</html>
