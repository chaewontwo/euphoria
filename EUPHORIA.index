<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EUPHORIA — for all animals in the world</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Noto+Sans+KR:wght@300;400;500;600;700;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --forest-deep:#26362c;
    --forest:#4f7a52;
    --forest-mid:#6a9370;
    --forest-light:#a9c5ab;
    --sand:#f6f3ea;
    --sand-dark:#ece6d6;
    --paper:#fffdf8;
    --gold:#c08a34;
    --gold-light:#e7c988;
    --ink:#232823;
    --line:#d9d2bd;
    --white:#ffffff;
    --radius:18px;
    --shadow:0 10px 30px -12px rgba(38,54,44,0.18);
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    margin:0;
    background:var(--sand);
    color:var(--ink);
    font-family:'Noto Sans KR',sans-serif;
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3,h4,.display{
    font-family:'Space Grotesk','Noto Sans KR',sans-serif;
    color:var(--forest-deep);
    margin:0;
    letter-spacing:-0.01em;
  }
  .mono{font-family:'JetBrains Mono',monospace;}
  a{color:inherit;text-decoration:none;}
  button{font-family:inherit;cursor:pointer;}
  img{max-width:100%;display:block;}
  .wrap{max-width:1180px;margin:0 auto;padding:0 28px;}
  .eyebrow{
    font-family:'JetBrains Mono',monospace;
    font-size:12px;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:var(--forest);
    font-weight:600;
    margin-bottom:12px;
    display:inline-block;
  }

  /* ---------- HEADER ---------- */
  header{
    position:sticky;top:0;z-index:100;
    background:rgba(246,243,234,0.86);
    backdrop-filter:blur(10px);
    border-bottom:1px solid var(--line);
  }
  .nav{
    display:flex;align-items:center;justify-content:space-between;
    padding:14px 0;
  }
  .brand{display:flex;align-items:center;gap:10px;}
  .brand svg{width:34px;height:34px;}
  .brand-text{display:flex;flex-direction:column;line-height:1.1;}
  .brand-text .name{font-family:'Space Grotesk';font-weight:700;font-size:19px;letter-spacing:0.03em;color:var(--forest-deep);}
  .brand-text .tag{font-size:10px;color:var(--forest-mid);letter-spacing:0.02em;}
  .nav-links{display:flex;align-items:center;gap:6px;}
  .nav-links button{
    background:none;border:none;padding:10px 16px;border-radius:100px;
    font-size:14.5px;font-weight:500;color:var(--forest-deep);
    transition:background .2s;
  }
  .nav-links button:hover,.nav-links button.active{background:var(--sand-dark);}
  .nav-cta{
    background:var(--forest-deep);color:var(--white)!important;
    padding:10px 20px!important;border-radius:100px;font-weight:600!important;
    margin-left:6px;
  }
  .nav-cta:hover{background:var(--forest)!important;}

  /* ---------- HERO ---------- */
  .hero{padding:76px 0 60px;}
  .hero-grid{display:grid;grid-template-columns:1.05fr 0.95fr;gap:56px;align-items:center;}
  .hero h1{font-size:47px;line-height:1.12;font-weight:700;}
  .hero h1 em{font-style:normal;color:var(--forest);}
  .hero p.lead{font-size:16.5px;color:#4c5850;max-width:480px;margin-top:18px;}
  .hero-actions{display:flex;gap:12px;margin-top:30px;flex-wrap:wrap;}
  .btn{
    padding:13px 24px;border-radius:100px;font-weight:600;font-size:14.5px;
    border:1.5px solid var(--forest-deep);transition:.2s;display:inline-flex;align-items:center;gap:8px;
  }
  .btn-primary{background:var(--forest-deep);color:var(--white);}
  .btn-primary:hover{background:var(--forest);border-color:var(--forest);}
  .btn-ghost{background:transparent;color:var(--forest-deep);}
  .btn-ghost:hover{background:var(--sand-dark);}
  .btn-gold{border-color:var(--gold);background:var(--gold);color:#fff;}
  .btn-gold:hover{background:#a97a2c;}
  .btn-sm{padding:9px 16px;font-size:13px;}
  .btn-block{width:100%;justify-content:center;}

  /* passbook signature widget */
  .passbook{
    background:var(--forest-deep);
    border-radius:22px;
    padding:30px 28px 26px;
    color:var(--sand);
    box-shadow:var(--shadow);
    position:relative;
    overflow:hidden;
  }
  .passbook::before{
    content:"";position:absolute;top:-60px;right:-60px;width:200px;height:200px;
    border-radius:50%;background:radial-gradient(circle,var(--forest) 0%, transparent 70%);opacity:.5;
  }
  .passbook-top{display:flex;justify-content:space-between;align-items:flex-start;position:relative;}
  .passbook-top .label{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--forest-light);font-family:'JetBrains Mono';}
  .passbook-top .acct{font-family:'JetBrains Mono';font-size:12px;color:var(--forest-light);margin-top:4px;}
  .pb-icon{width:30px;height:30px;opacity:.85;}
  .balance-row{margin-top:26px;position:relative;}
  .balance-row .cur-label{font-size:12px;color:var(--forest-light);margin-bottom:8px;font-family:'JetBrains Mono';}
  .digits{display:flex;gap:4px;flex-wrap:wrap;}
  .digit{
    font-family:'JetBrains Mono';font-weight:700;font-size:30px;
    width:34px;height:46px;display:flex;align-items:center;justify-content:center;
    border-radius:8px;background:rgba(255,255,255,0.06);cursor:pointer;
    color:var(--forest-light);transition:.15s;border:2px solid transparent;
  }
  .digit.kept{color:var(--sand);background:rgba(255,255,255,0.08);}
  .digit.donate{color:#2a1e0a;background:var(--gold-light);}
  .digit:hover{border-color:var(--gold);}
  .comma{width:8px;display:flex;align-items:flex-end;justify-content:center;font-family:'JetBrains Mono';color:var(--forest-light);padding-bottom:8px;}
  .pb-hint{font-size:12.5px;color:var(--forest-light);margin-top:10px;}
  .pb-result{
    margin-top:20px;background:rgba(0,0,0,0.18);border-radius:14px;padding:16px 18px;
    display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;
  }
  .pb-result .r-label{font-size:12px;color:var(--forest-light);}
  .pb-result .r-amount{font-family:'JetBrains Mono';font-size:22px;font-weight:700;color:var(--gold-light);}
  .pb-period{display:flex;gap:6px;margin-top:14px;}
  .pb-period button{
    flex:1;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:var(--sand);
    border-radius:9px;padding:9px 4px;font-size:12.5px;font-weight:500;
  }
  .pb-period button.active{background:var(--gold);color:#2a1e0a;border-color:var(--gold);font-weight:700;}

  /* ---------- SECTION SHELL ---------- */
  section.block{padding:86px 0;}
  section.block.alt{background:var(--paper);border-top:1px solid var(--line);border-bottom:1px solid var(--line);}
  .block-head{display:flex;justify-content:space-between;align-items:flex-end;gap:24px;margin-bottom:40px;flex-wrap:wrap;}
  .block-head h2{font-size:33px;font-weight:700;}
  .block-head p{color:#586359;font-size:15px;max-width:460px;margin-top:8px;}

  /* ---------- ANIMAL SECTION ---------- */
  .filters{display:flex;gap:8px;margin-bottom:28px;flex-wrap:wrap;}
  .filters button{
    padding:9px 18px;border-radius:100px;border:1.5px solid var(--line);background:var(--white);
    font-size:13.5px;font-weight:500;color:var(--forest-deep);transition:.15s;
  }
  .filters button.active{background:var(--forest-deep);color:#fff;border-color:var(--forest-deep);}

  .animal-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(268px,1fr));gap:22px;}
  .a-card{
    background:var(--white);border-radius:var(--radius);overflow:hidden;border:1px solid var(--line);
    display:flex;flex-direction:column;transition:.2s;
  }
  .a-card:hover{transform:translateY(-3px);box-shadow:var(--shadow);}
  .a-media{
    height:150px;display:flex;align-items:center;justify-content:center;font-size:58px;
    position:relative;
  }
  .a-tag{
    position:absolute;top:10px;left:10px;background:rgba(255,255,255,0.9);color:var(--forest-deep);
    font-size:10.5px;font-weight:700;padding:4px 10px;border-radius:100px;letter-spacing:.02em;
  }
  .a-body{padding:18px 18px 20px;display:flex;flex-direction:column;gap:9px;flex:1;}
  .a-body .a-name{font-size:16.5px;font-weight:700;color:var(--forest-deep);font-family:'Space Grotesk';}
  .a-body .a-org{font-size:12px;color:var(--forest-mid);font-weight:500;}
  .a-body .a-story{font-size:13px;color:#5b655c;flex:1;}
  .progress{height:7px;background:var(--sand-dark);border-radius:100px;overflow:hidden;margin-top:6px;}
  .progress > div{height:100%;background:linear-gradient(90deg,var(--forest),var(--forest-mid));}
  .a-stats{display:flex;justify-content:space-between;font-size:11.5px;color:#586359;font-family:'JetBrains Mono';}
  .a-actions{display:flex;gap:8px;margin-top:6px;}
  .a-actions .btn{flex:1;justify-content:center;padding:9px 10px;font-size:12.8px;}

  .add-card{
    border:2px dashed var(--line);border-radius:var(--radius);display:flex;flex-direction:column;
    align-items:center;justify-content:center;gap:10px;min-height:280px;background:transparent;
    color:var(--forest-mid);font-weight:600;font-size:13.5px;text-align:center;padding:20px;
  }
  .add-card:hover{border-color:var(--forest);color:var(--forest-deep);background:var(--sand-dark);}
  .add-card .plus{width:44px;height:44px;border-radius:50%;background:var(--forest-deep);color:#fff;display:flex;align-items:center;justify-content:center;font-size:22px;}

  /* ---------- DONATION SECTION ---------- */
  .donate-shell{display:grid;grid-template-columns:1fr 1.15fr;gap:34px;align-items:start;}
  .step-card{
    background:var(--white);border:1px solid var(--line);border-radius:var(--radius);padding:26px;margin-bottom:18px;
  }
  .step-card h4{font-size:14px;display:flex;align-items:center;gap:10px;margin-bottom:16px;}
  .step-num{width:24px;height:24px;border-radius:50%;background:var(--forest-deep);color:#fff;font-size:12px;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono';flex-shrink:0;}
  .selected-animal{display:flex;gap:12px;align-items:center;padding:10px;background:var(--sand);border-radius:12px;}
  .selected-animal .emoji{font-size:34px;}
  .selected-animal .info .n{font-weight:700;color:var(--forest-deep);font-size:14.5px;}
  .selected-animal .info .s{font-size:12px;color:#5b655c;}
  .pick-list{display:flex;gap:8px;overflow-x:auto;padding-bottom:6px;}
  .pick-chip{
    flex-shrink:0;padding:8px 14px;border-radius:100px;border:1.5px solid var(--line);background:var(--sand);
    font-size:12.5px;font-weight:500;white-space:nowrap;
  }
  .pick-chip.active{background:var(--forest-deep);color:#fff;border-color:var(--forest-deep);}
  .link-box{border:1.5px dashed var(--line);border-radius:12px;padding:16px;text-align:center;}
  .link-box.linked{border-style:solid;border-color:var(--forest);background:#f2f7f2;}
  .row-inline{display:flex;gap:10px;align-items:center;}
  .slider-wrap{margin-top:6px;}
  input[type=range]{width:100%;accent-color:var(--forest);}
  .digit-num{font-family:'JetBrains Mono';font-weight:700;font-size:22px;color:var(--forest-deep);}
  .period-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:6px;}
  .period-grid button{
    padding:10px 4px;border-radius:10px;border:1.5px solid var(--line);background:var(--sand);font-size:12.5px;font-weight:500;
  }
  .period-grid button.active{background:var(--forest-deep);color:#fff;border-color:var(--forest-deep);}

  .summary-card{
    background:var(--forest-deep);color:var(--sand);border-radius:var(--radius);padding:28px;
    position:sticky;top:96px;
  }
  .summary-card h4{color:var(--sand);font-size:15px;margin-bottom:18px;font-family:'Space Grotesk';}
  .summary-line{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.1);font-size:13.5px;}
  .summary-line span:first-child{color:var(--forest-light);}
  .summary-amount{
    margin-top:18px;background:rgba(255,255,255,0.07);border-radius:12px;padding:18px;text-align:center;
  }
  .summary-amount .amt{font-family:'JetBrains Mono';font-size:30px;font-weight:700;color:var(--gold-light);}
  .summary-amount .per{font-size:12px;color:var(--forest-light);margin-top:4px;}
  .hist{margin-top:26px;}
  .hist h5{font-size:12px;letter-spacing:.06em;color:var(--forest-light);text-transform:uppercase;margin-bottom:10px;font-family:'JetBrains Mono';}
  .hist-item{display:flex;justify-content:space-between;font-size:12.5px;padding:8px 0;border-bottom:1px dashed rgba(255,255,255,0.12);}
  .hist-item .h-amt{font-family:'JetBrains Mono';color:var(--gold-light);}
  .empty-note{font-size:12.5px;color:var(--forest-light);}

  /* ---------- INSTITUTION SECTION ---------- */
  .org-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:18px;margin-bottom:44px;}
  .org-card{background:var(--white);border:1px solid var(--line);border-radius:16px;padding:20px;}
  .org-card .o-icon{width:42px;height:42px;border-radius:50%;background:var(--sand-dark);display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:12px;}
  .org-card .o-name{font-weight:700;color:var(--forest-deep);font-size:15px;font-family:'Space Grotesk';}
  .org-card .o-loc{font-size:11.5px;color:var(--forest-mid);margin:3px 0 8px;}
  .org-card .o-desc{font-size:12.5px;color:#5b655c;}
  .org-card .o-meta{margin-top:12px;font-size:11.5px;font-family:'JetBrains Mono';color:var(--forest);font-weight:600;}

  .org-forms{display:grid;grid-template-columns:1fr 1fr;gap:24px;}
  .form-card{background:var(--white);border:1px solid var(--line);border-radius:var(--radius);padding:28px;}
  .form-card h3{font-size:18px;margin-bottom:6px;}
  .form-card .sub{font-size:12.5px;color:#5b655c;margin-bottom:20px;}
  .field{margin-bottom:14px;}
  .field label{font-size:12.5px;font-weight:600;color:var(--forest-deep);display:block;margin-bottom:6px;}
  .field input,.field textarea,.field select{
    width:100%;padding:10px 12px;border-radius:9px;border:1.5px solid var(--line);background:var(--sand);
    font-family:inherit;font-size:13.5px;color:var(--ink);
  }
  .field textarea{resize:vertical;min-height:64px;}
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
  .upload-stub{
    border:1.5px dashed var(--line);border-radius:9px;padding:16px;text-align:center;font-size:12px;color:var(--forest-mid);background:var(--sand);
  }
  .form-note{font-size:11.5px;color:#889183;margin-top:10px;}

  /* ---------- FOOTER ---------- */
  footer{background:var(--forest-deep);color:var(--forest-light);padding:52px 0 26px;}
  .foot-grid{display:flex;justify-content:space-between;flex-wrap:wrap;gap:30px;padding-bottom:32px;border-bottom:1px solid rgba(255,255,255,0.1);}
  .foot-brand{display:flex;gap:10px;align-items:center;}
  .foot-brand .name{color:#fff;font-family:'Space Grotesk';font-weight:700;font-size:18px;}
  .foot-cols{display:flex;gap:60px;flex-wrap:wrap;}
  .foot-col h5{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--forest-light);margin-bottom:12px;font-family:'JetBrains Mono';}
  .foot-col a{display:block;font-size:13px;color:#d9e6da;margin-bottom:8px;}
  .foot-bottom{display:flex;justify-content:space-between;padding-top:20px;font-size:11.5px;color:#8aa38d;flex-wrap:wrap;gap:8px;}

  /* ---------- AUTH / USER ---------- */
  .auth-area{display:flex;align-items:center;gap:8px;}
  .user-chip{display:flex;align-items:center;gap:10px;padding:6px 6px 6px 16px;border-radius:100px;background:var(--sand-dark);}
  .user-chip .u-name{font-size:13px;font-weight:600;color:var(--forest-deep);white-space:nowrap;}
  .user-chip button{background:var(--forest-deep);color:#fff;border:none;border-radius:100px;padding:7px 14px;font-size:11.5px;font-weight:600;}
  .auth-tabs{display:flex;gap:6px;margin:16px 0 20px;background:var(--sand-dark);padding:4px;border-radius:100px;}
  .auth-tabs button{flex:1;padding:9px;border:none;background:transparent;border-radius:100px;font-size:13px;font-weight:600;color:var(--forest-mid);}
  .auth-tabs button.active{background:var(--forest-deep);color:#fff;}
  .auth-note{font-size:11.5px;color:#8a9488;margin-top:14px;text-align:center;line-height:1.5;}

  /* ---------- MYPAGE ---------- */
  .mypage-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:24px;align-items:start;}
  .mp-card{background:var(--white);border:1px solid var(--line);border-radius:var(--radius);padding:24px;margin-bottom:18px;}
  .mp-card h4{font-size:14px;margin-bottom:14px;}
  .mp-locked{background:var(--white);border:1.5px dashed var(--line);border-radius:var(--radius);padding:54px 30px;text-align:center;}
  .mp-locked .lock-emoji{font-size:38px;margin-bottom:14px;}
  .mp-locked h3{font-size:17px;}
  .mp-locked p{font-size:13px;color:#5b655c;margin:8px 0 20px;}
  .mp-account-row{display:flex;justify-content:space-between;align-items:center;padding:10px 0;font-size:13px;border-bottom:1px dashed var(--line);}
  .mp-table{width:100%;border-collapse:collapse;font-size:12.8px;}
  .mp-table th{text-align:left;color:var(--forest-mid);font-weight:600;font-size:10.8px;text-transform:uppercase;letter-spacing:.04em;padding:8px 6px;border-bottom:1.5px solid var(--line);font-family:'JetBrains Mono';}
  .mp-table td{padding:10px 6px;border-bottom:1px solid var(--sand-dark);font-size:12.5px;}
  .mp-table .amt{font-family:'JetBrains Mono';color:var(--forest);font-weight:600;}

  /* ---------- GUIDE MODAL ---------- */
  .modal.wide{max-width:600px;}
  .guide-item{display:flex;gap:14px;padding:15px 0;border-bottom:1px solid var(--line);text-align:left;}
  .guide-item:last-child{border-bottom:none;}
  .guide-num{width:28px;height:28px;border-radius:50%;background:var(--forest-deep);color:#fff;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono';font-size:12.5px;flex-shrink:0;}
  .guide-item h5{font-size:13.5px;color:var(--forest-deep);margin-bottom:3px;font-family:'Space Grotesk';}
  .guide-item p{font-size:12.5px;color:#5b655c;margin:0;line-height:1.55;}

  /* ---------- MODAL ---------- */
  .modal-bg{
    position:fixed;inset:0;background:rgba(35,40,35,0.55);backdrop-filter:blur(2px);
    display:none;align-items:center;justify-content:center;z-index:1000;padding:20px;
  }
  .modal-bg.open{display:flex;}
  .modal{
    background:var(--paper);border-radius:20px;max-width:520px;width:100%;max-height:86vh;overflow-y:auto;
    padding:30px;position:relative;
  }
  .modal-close{
    position:absolute;top:16px;right:16px;width:32px;height:32px;border-radius:50%;background:var(--sand-dark);
    border:none;font-size:16px;color:var(--forest-deep);display:flex;align-items:center;justify-content:center;
  }
  .modal .m-emoji{font-size:52px;text-align:center;margin-bottom:10px;}
  .modal h3{text-align:center;font-size:20px;}
  .modal .m-org{text-align:center;font-size:12.5px;color:var(--forest-mid);margin-top:4px;margin-bottom:16px;}
  .modal .m-story{font-size:14px;color:#4c5850;background:var(--sand);padding:16px;border-radius:12px;margin-bottom:18px;}
  .toast{
    position:fixed;bottom:26px;left:50%;transform:translateX(-50%) translateY(120%);
    background:var(--forest-deep);color:#fff;padding:14px 24px;border-radius:100px;font-size:13.5px;font-weight:500;
    box-shadow:var(--shadow);z-index:1200;transition:transform .3s ease;display:flex;align-items:center;gap:8px;
  }
  .toast.show{transform:translateX(-50%) translateY(0);}

  @media(max-width:900px){
    .hero-grid{grid-template-columns:1fr;}
    .donate-shell{grid-template-columns:1fr;}
    .summary-card{position:static;}
    .org-forms{grid-template-columns:1fr;}
    .mypage-grid{grid-template-columns:1fr;}
    .nav-links{display:none;}
    .hero h1{font-size:34px;}
    .field-row{grid-template-columns:1fr;}
  }
</style>
</head>
<body>

<!-- ===================== HEADER ===================== -->
<header>
  <div class="wrap nav">
    <div class="brand">
      <svg viewBox="0 0 64 78" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M32 2C17 2 6 13 6 27c0 18 22 40 24 42 2-2 24-24 24-42C54 13 43 2 32 2z" stroke="#4f7a52" stroke-width="3" fill="none"/>
        <circle cx="32" cy="27" r="17" stroke="#4f7a52" stroke-width="2.4" fill="none"/>
