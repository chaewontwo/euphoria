<!-- ===================== HERO ===================== -->
<section class="hero">
  <div class="wrap hero-grid">
    <div>
      <span class="eyebrow">Digit Donation System</span>
      <h1>통장 속 자투리 숫자가<br><em>한 생명</em>을 살립니다</h1>
      <p class="lead">EUPHORIA는 유기동물, 은퇴 경주마처럼 사연을 가진 동물들을 소개하고, 부담 없는 방식으로 모금을 이어주는 통합 플랫폼입니다. 통장 잔액의 원하는 자릿수만큼만, 정한 주기마다 자동으로 기부하세요.</p>
      <div class="hero-actions">
        <button class="btn btn-primary" data-nav="animals">동물 이야기 보러가기 →</button>
        <button class="btn btn-ghost" data-nav="orgs">기관으로 참여하기</button>
      </div>
    </div>

    <div class="passbook" id="heroPassbook">
      <div class="passbook-top">
        <div>
          <div class="label">My Passbook</div>
          <div class="acct">EUPHORIA · 302-●●●●-1128</div>
        </div>
        <svg class="pb-icon" viewBox="0 0 24 24" fill="none"><rect x="2" y="4" width="20" height="16" rx="3" stroke="#a9c5ab" stroke-width="1.6"/><path d="M2 9h20" stroke="#a9c5ab" stroke-width="1.6"/></svg>
      </div>
      <div class="balance-row">
        <div class="cur-label">현재 잔액 — 자릿수를 눌러 기부 범위를 선택하세요</div>
        <div class="digits" id="heroDigits"></div>
        <div class="pb-hint" id="heroHint"></div>
      </div>
      <div class="pb-result">
        <div>
          <div class="r-label">선택 주기마다 자동 기부</div>
          <div class="r-amount mono" id="heroAmount">₩0</div>
        </div>
        <div>
          <div class="r-label">기부 후 잔액</div>
          <div class="r-amount mono" id="heroKept" style="color:#d9e6da;font-size:16px;">₩0</div>
        </div>
      </div>
      <div class="pb-period" id="heroPeriod"></div>
    </div>
  </div>
</section>

<!-- ===================== 동물 소개 ===================== -->
<section class="block" id="animals">
  <div class="wrap">
    <div class="block-head">
      <div>
        <span class="eyebrow">Animal Stories</span>
        <h2>동물들의 이야기</h2>
        <p>기관과 운영진이 직접 등록한 동물들의 사연입니다. 마음이 가는 동물을 선택해 모금에 참여해보세요.</p>
      </div>
    </div>
    <div class="filters" id="filters"></div>
    <div class="animal-grid" id="animalGrid"></div>
  </div>
</section>

<!-- ===================== 모금 ===================== -->
<section class="block alt" id="donate">
  <div class="wrap">
    <div class="block-head">
      <div>
        <span class="eyebrow">Fundraising</span>
        <h2>자릿수 모금 시작하기</h2>
        <p>동물을 선택하고, 통장을 연결한 뒤, 기부할 자릿수와 주기를 정하면 끝. 매번 신경 쓰지 않아도 자동으로 기부됩니다.</p>
      </div>
    </div>

    <div class="donate-shell">
      <div>
        <div class="step-card">
          <h4><span class="step-num">1</span> 기부할 동물 선택</h4>
          <div class="pick-list" id="pickList"></div>
          <div class="selected-animal" id="selectedAnimalBox" style="margin-top:14px;"></div>
        </div>

        <div class="step-card">
          <h4><span class="step-num">2</span> 통장 연결</h4>
          <div class="link-box" id="linkBox"></div>
        </div>

        <div class="step-card">
          <h4><span class="step-num">3</span> 기부 자릿수 선택 <span style="font-weight:400;color:#8a9488;">(1~100 자리)</span></h4>
          <div class="row-inline" style="justify-content:space-between;">
            <span style="font-size:12.5px;color:#586359;">선택한 자릿수까지 기부</span>
            <span class="digit-num" id="digitVal">3</span>
          </div>
          <div class="slider-wrap">
            <input type="range" min="1" max="100" value="3" id="digitSlider">
          </div>
          <div class="digits" id="donateDigits" style="margin-top:14px;"></div>
        </div>

        <div class="step-card">
          <h4><span class="step-num">4</span> 기부 주기 선택</h4>
          <div class="period-grid" id="periodGrid"></div>
        </div>
      </div>

      <div class="summary-card">
        <h4>기부 요약</h4>
        <div class="summary-line"><span>대상 동물</span><span id="sumAnimal">—</span></div>
        <div class="summary-line"><span>현재 잔액</span><span class="mono" id="sumBalance">₩0</span></div>
        <div class="summary-line"><span>기부 자릿수</span><span id="sumDigit">3자리</span></div>
        <div class="summary-line"><span>기부 주기</span><span id="sumPeriod">매주</span></div>
        <div class="summary-amount">
          <div class="amt mono" id="sumAmount">₩0</div>
          <div class="per">주기마다 자동 기부됩니다</div>
        </div>
        <button class="btn btn-gold btn-block" style="margin-top:16px;" id="confirmDonate">이 조건으로 정기 기부 시작</button>

        <div class="hist">
          <h5>나의 기부 내역</h5>
          <div id="histList"><div class="empty-note">아직 기부 내역이 없어요.</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== 마이페이지 ===================== -->
