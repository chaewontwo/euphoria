<!-- ===================== 기관 연계 ===================== -->
<section class="block" id="orgs">
  <div class="wrap">
    <div class="block-head">
      <div>
        <span class="eyebrow">Partner Organizations</span>
        <h2>기관 연계</h2>
        <p>동물 보호 기관·단체가 보호 중인 동물의 정보를 직접 게시하고, 후원자와 연결될 수 있습니다.</p>
      </div>
    </div>

    <div class="org-grid" id="orgGrid"></div>

    <div class="org-forms">
      <div class="form-card">
        <h3>🐾 보호 동물 등록하기</h3>
        <div class="sub">기관 또는 운영자 전용 — 현재 보호 중인 동물의 정보를 게시합니다.</div>
        <form id="animalForm">
          <div class="field-row">
            <div class="field"><label>동물 이름</label><input required id="af_name" placeholder="예: 보리"></div>
            <div class="field"><label>종류</label>
              <select id="af_type">
                <option value="유기견">유기견</option>
                <option value="유기묘">유기묘</option>
                <option value="은퇴 경주마">은퇴 경주마</option>
                <option value="야생동물">야생동물</option>
                <option value="기타">기타</option>
              </select>
            </div>
          </div>
          <div class="field-row">
            <div class="field"><label>등록 기관명</label><input required id="af_org" placeholder="예: 서울 유기동물 보호센터"></div>
            <div class="field"><label>목표 모금액(원)</label><input required id="af_target" type="number" placeholder="1000000"></div>
          </div>
          <div class="field"><label>사연 소개</label><textarea required id="af_story" placeholder="이 동물의 사연을 자유롭게 소개해주세요."></textarea></div>
          <div class="field"><label>대표 이미지</label><div class="upload-stub">📷 이미지를 드래그하거나 클릭해서 업로드 (데모에서는 아이콘으로 대체됩니다)</div></div>
          <button type="submit" class="btn btn-primary btn-block">동물 등록하기</button>
          <div class="form-note">등록된 동물은 즉시 [동물 소개] 섹션에 노출됩니다.</div>
        </form>
      </div>

      <div class="form-card">
        <h3>🏛️ 기관 파트너 신청</h3>
        <div class="sub">EUPHORIA와 함께할 동물 보호 기관·단체를 상시 모집합니다.</div>
        <form id="orgForm">
          <div class="field-row">
            <div class="field"><label>기관명</label><input required id="of_name" placeholder="예: 제주 은퇴마 보호협회"></div>
            <div class="field"><label>소재지</label><input required id="of_loc" placeholder="예: 제주"></div>
          </div>
          <div class="field-row">
            <div class="field"><label>담당자명</label><input required id="of_person" placeholder="홍길동"></div>
            <div class="field"><label>연락처</label><input required id="of_phone" placeholder="010-0000-0000"></div>
          </div>
          <div class="field"><label>기관 소개</label><textarea required id="of_desc" placeholder="기관이 하는 일과 현재 보호 중인 동물 수 등을 소개해주세요."></textarea></div>
          <button type="submit" class="btn btn-primary btn-block">파트너 신청하기</button>
          <div class="form-note">신청 즉시 [기관 연계] 목록에 노출됩니다. (데모 화면)</div>
        </form>
      </div>
    </div>
  </div>
</section>

